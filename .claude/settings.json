{
  "enabledPlugins": {
    "compound-knowledge@compound-knowledge-plugin": true,
    "skill-creator@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "compound-knowledge-plugin": {
      "source": {
        "source": "github",
        "repo": "EveryInc/compound-knowledge-plugin"
      }
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PROJECT_DIR}/.claude/hooks/sync-skills-if-stale.sh"
          }
        ]
      }
    ]
  }
}
