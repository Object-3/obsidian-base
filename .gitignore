# --- Obsidian per-machine state (keep shared settings, drop local/cache) ---
.obsidian/workspace.json
.obsidian/workspace-mobile.json
.obsidian/cache
.obsidian/.cache/
.obsidian/updates.json

# Plugin code + runtime data: bulky bundled JS AND may hold secrets
# (e.g. the Local REST API plugin stores its apiKey in data.json). Never track —
# EXCEPT the Obsidian Git settings file, which holds no secrets and which we share
# so every vault inherits the recommended sync config (pull-on-start, merge, etc.).
.obsidian/plugins/*
!.obsidian/plugins/obsidian-git/
.obsidian/plugins/obsidian-git/*
!.obsidian/plugins/obsidian-git/data.json

# Trash
.trash/

# --- Sensitive plane + local-only originals (confidential notes; large/sensitive
#     originals: PDFs, images, datasets) ---
# These stay on your machine (optionally cloud-backed for durability) and NEVER reach
# GitHub. Keep a small markdown reference note in the vault instead (see AGENTS.md).
# The folder's README/.gitkeep are tracked so the folder ships with the template.
_sensitive/*
!_sensitive/.gitkeep
!_sensitive/README.md
# Back-compat: `_local/` was this folder's name before the rename to `_sensitive/`.
# Keep it ignored too, so a vault created before the rename never loses protection on
# its confidential notes after pulling base updates (the `/setup-sensitive-plane`
# `migrate` step renames the folder on disk; this line keeps it safe until then).
_local/*
!_local/.gitkeep
!_local/README.md

# Belt-and-suspenders for the _sensitive/ convention: any note suffixed *.private.md is
# NEVER tracked, wherever it sits in the vault — so a sensitive note stays out of git
# even outside _sensitive/. (Obsidian still indexes it; git ignores it.) Pairs with the
# pre-commit confidential guard and the /ingest-pdf workflow.
**/*.private.md

# --- Agent skill sync (regenerated each run; not the source of truth) ---
.agents/.skills-last-sync

# Local-only agent settings (per-machine overrides, may hold secrets)
.claude/settings.local.json

# --- MCP tooling artifacts (Playwright browser snapshots / console logs; regenerated per run) ---
.playwright-mcp/
.playwright/

# --- ce-optimize scratch artifacts (compound-engineering skill) ---
# The ce-optimize skill's own contract keeps experiment scratch state (measurement
# harnesses, eval questions, baseline snapshots) under .context/compound-engineering/
# ce-optimize/<spec-name>/, which is local-only and never meant to be committed. If that
# scratch ever gets copied into the tracked tree instead of .context/ (as happened once
# under .agents/scripts/ce-optimize-obsidian-mcp-quick-orient/), keep it out of git
# regardless of where it lands — match the skill's own <spec-name> naming convention.
**/ce-optimize-*/

# --- macOS / OS cruft ---
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*

# Local REST API key (per-machine secret for the Obsidian MCP)
.obsidian/.rest-api-key
